#include <iostream>
#include <vector>
using namespace std;

void dfs(int node, vector<int> adj[], vector<bool>& visited) {
    visited[node] = true;
    cout << node << " ";

    for(int neigh : adj[node]) {
        if(!visited[neigh])
            dfs(neigh, adj, visited);
    }
}

int main() {
    int n = 5;

    vector<int> adj[5];

    adj[0].push_back(1);
    adj[0].push_back(2);
    adj[1].push_back(3);
    adj[2].push_back(4);

    vector<bool> visited(n, false);

    dfs(0, adj, visited);

    return 0;
}
