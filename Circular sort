#include <iostream>
using namespace std;

#define SIZE 5

int cq[SIZE];
int front = -1, rear = -1;

void enqueue(int value) {

    if((rear + 1) % SIZE == front) {
        cout << "Queue Full\n";
        return;
    }

    if(front == -1)
        front = 0;

    rear = (rear + 1) % SIZE;

    cq[rear] = value;
}

void dequeue() {

    if(front == -1) {
        cout << "Queue Empty\n";
        return;
    }

    cout << "Deleted: " << cq[front] << endl;

    if(front == rear)
        front = rear = -1;
    else
        front = (front + 1) % SIZE;
}

void display() {

    if(front == -1) {
        cout << "Queue Empty";
        return;
    }

    int i = front;

    while(i != rear) {
        cout << cq[i] << " ";
        i = (i + 1) % SIZE;
    }

    cout << cq[rear];
}

int main() {

    enqueue(10);
    enqueue(20);
    enqueue(30);

    dequeue();

    display();

    return 0;
}
