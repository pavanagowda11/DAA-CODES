#include <iostream>
using namespace std;

#define MAX 5

int stackArr[MAX];
int top = -1;

void push(int val) {
    if(top == MAX - 1)
        cout << "Stack Overflow\n";
    else {
        top++;
        stackArr[top] = val;
    }
}

void pop() {
    if(top == -1)
        cout << "Stack Underflow\n";
    else {
        cout << "Deleted: " << stackArr[top] << endl;
        top--;
    }
}

void display() {
    for(int i = top; i >= 0; i--)
        cout << stackArr[i] << " ";
}

int main() {
    push(10);
    push(20);
    push(30);

    pop();

    display();

    return 0;
}
