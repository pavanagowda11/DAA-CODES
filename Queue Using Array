#include <iostream>
using namespace std;

#define SIZE 5

int queueArr[SIZE];
int front = -1, rear = -1;

void enqueue(int val) {
    if(rear == SIZE - 1)
        cout << "Queue Full\n";
    else {
        if(front == -1)
            front = 0;

        rear++;
        queueArr[rear] = val;
    }
}

void dequeue() {
    if(front == -1 || front > rear)
        cout << "Queue Empty\n";
    else {
        cout << "Deleted: " << queueArr[front] << endl;
        front++;
    }
}

void display() {
    for(int i = front; i <= rear; i++)
        cout << queueArr[i] << " ";
}

int main() {
    enqueue(10);
    enqueue(20);
    enqueue(30);

    dequeue();

    display();

    return 0;
}
